{
  "tasks": {
    "cli": "deno run --allow-net --allow-env --allow-run=gh src/cli/main.ts",
    "web": "deno run --allow-net --allow-env --allow-run=gh --allow-read=./src/web/static src/web/main.ts",
    "test": "deno test --allow-env tests/",
    "compile": "deno compile --allow-net --allow-env --allow-run=gh --output github-stats src/cli/main.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@std/cli": "jsr:@std/cli@^1",
    "@hono/hono": "jsr:@hono/hono@^4"
  }
}
